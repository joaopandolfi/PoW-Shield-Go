# you can check the default values on server/config/config.go

#==== SERVER
PORT=5656
#SEC_BROWSER_XSS_FILTER=
#SEC_CONTENT_TYPE_NO_SNIFF=
#SEC_SSL_HOST=
#SEC_SSL_REDIRECT=
#WRITE_TIMEOUT_SECONDS=30
#READ_TIMEOUT_SECONDS=30
#SESSION_NAME=
#SESSION_PASS=
#SESSION_PATH=
#SESSION_MAX_AGE=
#SESSION_HTTP_ONLY=
#SESSION_SECURE=

#==== CLIENT
#SERVE_STATIC=
#SERVE_STATIC_PATH=
#SERVE_STATIC_FOLDER=

#==== POW
#DEFAULT_PREFIX_SIZE=
#PUNISHMENT=1
#NONCE_VALIDITY=
#USE_COOKIE=
#USE_SESSION=
#USE_HEADER=
#POW_ACTIVE=
#IP_TOLLERANCE_DURATION_SECONDS=120
#IP_TOLLERANCE=1

#==== RATE LIMIT
#RATE_LIMIT_ACTIVE=true
#RATE_LIMIT_REQUESTS=120
#RATE_LIMIT_WINDOW_SECONDS=60

#==== PROTECTED_SERVER
#PROTECTED_SERVER_HOST=
#PROTECTED_SERVER_HEADERS=
#PROTECTED_SERVER_TIMEOUT_SECONDS=30
#PROTECTED_SERVER_INSECURE_SKIP_VERIFY=false

#==== RESPONSE
#BLOCK_RESPONSE_STATUS=406
#BLOCK_RESPONSE_BODY=blocked: x_x
#BLOCK_RESPONSE_CONTENT_TYPE=text/plain; charset=utf-8

#==== WAF
#WAF_ACTIVE=
WHITELIST_URL_RULES=[35,53]
WHITELIST_BODY_RULES=[35,53]
WHITELIST_HEADER_RULES=[33,35,53]
#WAF_ALLOW_TYPES=["xss","sqli"]
#WAF_BLOCK_TYPES=["spam"]
#WAF_RULES_FILE=
#WAF_TYPES_FILE=

#==== REDIS
REDIS_USE=false
#REDIS_DB=1
#REDIS_HOST=127.0.0.1:6379
#REDIS_PASS=

#==== TLS
USE_TLS=false
#TLS_CERT=
#TLS_KEY=

#==== METRICS
#METRICS_ACTIVE=true
#METRICS_PATH=/metrics

#==== LOGGING
#LOG_LEVEL=INFO
#LOG_FILE_PATH=
#LOG_STACKTRACE=false
#LOG_ENVIRONMENT=development

#==== ADMIN DASHBOARD
#ADMIN_ACTIVE=false
#ADMIN_PATH=/admin
